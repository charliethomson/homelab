# Discord bot token (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Discord application client ID and OAuth secret (Developer Portal → OAuth2)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Genius API token (optional, for lyrics) — genius.com/api-clients
GENIUS_TOKEN=

# Lavalink internal password (anything, not exposed externally)
LAVALINK_PASSWORD=

# MongoDB credentials (must match mongodb_url in settings.json)
MONGO_USERNAME=
MONGO_PASSWORD=

# Dashboard IPC password (shared between bot and dashboard, anything)
DASHBOARD_IPC_PASSWORD=

# Dashboard session secret key (random string, e.g. openssl rand -hex 32)
DASHBOARD_SECRET_KEY=

# Spotify API credentials — developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
