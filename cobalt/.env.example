# Public URL — Caddy strips /api/cobalt before forwarding to localhost:9000,
# so this must be the externally-visible URL including the prefix.
API_URL=https://dev.lan.thmsn.dev/api/cobalt/

# API key clients send as `Authorization: Api-Key <value>`.
# Must be a UUIDv4 — generate with: uuidgen | tr '[:upper:]' '[:lower:]'
COBALT_API_KEY=
