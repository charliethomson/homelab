# ProtonVPN WireGuard private key
# Found at: account.proton.me → VPN → WireGuard → create/download a config
WIREGUARD_PRIVATE_KEY=

# *arr API keys — generate with `openssl rand -hex 16`, set before first run
# enforced on every startup so inter-service connections stay stable
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=

# qBittorrent WebUI credentials — used by Flood and port-updater to connect
# defaults to admin/adminadmin if unset
QB_USER=
QB_PASS=

# Soulseek credentials for slskd — requires a free soulseek account
SLSKD_USERNAME=
SLSKD_PASSWORD=
