# ProtonVPN WireGuard private key
# Found at: account.proton.me → VPN → WireGuard → create/download a config
WIREGUARD_PRIVATE_KEY=

# *arr API keys — generate with `openssl rand -hex 32`, set before first run
# enforced on every startup so inter-service connections stay stable
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=
